        if key not in allimages:
            continue
        
        # print('vp size:',vp_size)
        # Find closest image to the target time
        image_list = allimages[key]
        closest_data = min(image_list, key=lambda x: abs(x['elapsed_hours'] - target_elapsed_hours))
        
        # ROI and media region
        image = closest_data['image']
        roi = image[row_start:row_end, col_start:col_end]
        roi = np.rot90(roi, k=-1)
        
        # Line trace row
        line_row = line_trace_row_rel
        line_trace = roi[line_row, :]
        trace_med = median_filter(line_trace, size=3)
        smoothed_trace = gaussian_filter1d(trace_med, sigma=2)
        raw_traces.append(smoothed_trace)
        
        # Normalized trace
        media_region = image[media_row_start:media_row_end, media_col_start:media_col_end]
        norm_trace = smoothed_trace / np.median(media_region)
        normalized_traces.append(norm_trace)
        vp_labels.append(f"VP {vp_size}")
        
        # Plot image
        bins = 256
        hist, bin_edges = np.histogram(roi, bins=bins)
        nonzero_bins = np.where(hist > 5)[0]
        vmin = bin_edges[nonzero_bins[0]]
        vmax = bin_edges[nonzero_bins[-1]]
        # print('normalized vmin',vmin)
        # print('normalized vmax',vmax)
        im = ax.imshow(roi, cmap='Blues_r', origin='lower', vmin=vmin, vmax=vmax)
        
