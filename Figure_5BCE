# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Read from the HDF5 file and create the 'allimages' dictionary (using the same start_timestamp_str)

allimages = {}

with h5py.File(output_h5_filename, 'r') as hf:
    for group_name in hf.keys():
        allimages[group_name] = []
        group = hf[group_name]

        # Sort the datasets within each group by 'sizing' attribute
        sorted_datasets_items = sorted(group.items(), key=lambda item: item[1].attrs['sizing'])  # Sorting by 'sizing' attribute
        if not sorted_datasets_items:
            continue

        # Get the timestamp of the first dataset within the current group.
        first_dataset = sorted_datasets_items[0][1] # Get the first dataset object from the sorted list.
        time_start_str = first_dataset.attrs['timestamp']
        time_start = datetime.strptime(time_start_str, "%Y%m%d_%H%M%S") # Convert to datetime object.

        for dataset_name, dset in sorted_datasets_items:

                image_data = dset[:]
                timestamp_str = dset.attrs['timestamp']
                sizing = dset.attrs['sizing']
                current_timestamp = datetime.strptime(timestamp_str, "%Y%m%d_%H%M%S")
    
                elapsed = current_timestamp - time_start # Calculate elapsed time relative to the first image in *this* group.
                elapsed_hours = round(elapsed.total_seconds() / 3600.0, 2)
    
                allimages[group_name].append({
                    'image': image_data,
                    'elapsed_hours': elapsed_hours,
                    'sizing': sizing
                })


