    ax1.set_ylabel(r"$\frac{\mathrm{Capacitance}}{\mathrm{Capacitance}_{\mathrm{media}}}$")
    # ax1.set_title(f'Mean Capacitance near Pixel {target_pixel_1}', fontsize=16)
    # ax1.grid(True)
    ax1.set_ylim(0.6, 1.6)
    ax1.set_xlim(0,50)

    for sizing in sorted(grouped_data.keys()):
        if sizing in size_color_map:
            time_series = grouped_data[sizing]['time']
            pixel_series = grouped_data[sizing][f'pixel_{target_pixel_1}']
            smoothed_pixel_series = gaussian_filter1d(pixel_series, sigma=2)
            ax1.plot(time_series, smoothed_pixel_series,
                     color=size_color_map[sizing], label=f'Size = {sizing}', linewidth=2, alpha=0.8)

