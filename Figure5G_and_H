trace_data = {'sizing':[], f'pixel_{target_pixel_1}':[], f'pixel_{target_pixel_2}':[], 'elapsed_time':[]}
myframes = []


if 1:
    all_keys = list(allimages.keys())
    virtual_keys = [k for k in all_keys if k.startswith('Virtual_pixel_size')]

    if not virtual_keys:
        print("No virtual pixel size categories found. Exiting plotting loop.")
        exit()

    # Sort keys by sizing (virtual pixel size)
    virtual_keys_sorted = sorted(virtual_keys, key=lambda k: allimages[k][0]['sizing'])

    size_color_map = {
        1: 'blue',
        2: 'green',
        4: 'red',
        8: 'magenta',
    }

    for j in range(len(allimages[virtual_keys_sorted[0]])):
        
        line_traces_data = []
        scaled_line_traces_data = []

        for i, k in enumerate(virtual_keys_sorted):
            img = allimages[k][j]['image'][row_start:row_end, col_start:col_end]
            sizing = allimages[k][j]['sizing']
            
            #If rotation is needed
            if 1: 
                img_roi = np.rot90(img, k=-1)
          

            # Trace processing
            line_trace = img_roi[line_trace_row_rel, :]
            trace_med = median_filter(line_trace, size=3)
            line_trace_smooth = gaussian_filter1d(trace_med, sigma=2)
            line_traces_data.append(line_trace_smooth)

            # Media normalization
            media_roi = allimages[k][j]['image'][media_row_start:media_row_end, media_col_start:media_col_end]
            media_median = np.median(media_roi)
            if media_median == 0:
                print(f"Warning: media median is zero at j={j}, k={k}")
                media_median = 1.0
            scaled_trace = line_trace_smooth / media_median
            scaled_line_traces_data.append(scaled_trace)

            # Define new pixel centers
            center_1 = target_pixel_1
            center_2 = target_pixel_2
            
            # ~~~ Extract 2x2 region around pixel 155 ~~~
            pixel_1_values = []
            for row_offset in [0, 1]:
                for col_offset in [0, 1]:
                    row_idx = line_trace_row_rel + row_offset
                    col_idx = center_1 + col_offset
                    if row_idx < img_roi.shape[0] and col_idx < img_roi.shape[1]:
                        pixel_1_values.append(img_roi[row_idx, col_idx] / media_median)
            
            # ~~~ Extract 2x2 region around pixel 100 ~~~
            pixel_2_values = []
            for row_offset in [0, 1]:
                for col_offset in [0, 1]:
                    row_idx = line_trace_row_rel + row_offset
                    col_idx = center_2 + col_offset
                    if row_idx < img_roi.shape[0] and col_idx < img_roi.shape[1]:
                        pixel_2_values.append(img_roi[row_idx, col_idx] / media_median)
            
            # Compute the averages
            mean_1 = np.mean(pixel_1_values) if pixel_1_values else np.nan
            mean_2 = np.mean(pixel_2_values) if pixel_2_values else np.nan
            
            # Store trace data
            trace_data['sizing'].append(sizing)
            trace_data['elapsed_time'].append(allimages[k][j]['elapsed_hours'])
            trace_data[f'pixel_{target_pixel_1}'].append(mean_1)
            trace_data[f'pixel_{target_pixel_2}'].append(mean_2)

      
        
if 1:
    from collections import defaultdict

    size_color_map = {
