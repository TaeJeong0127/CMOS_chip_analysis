        8: 'magenta',
    }

    grouped_data = defaultdict(lambda: {'time': [], f'pixel_{target_pixel_1}': [], f'pixel_{target_pixel_2}': []})

    for i, sizing in enumerate(trace_data['sizing']):
        grouped_data[sizing]['time'].append(trace_data['elapsed_time'][i])
        grouped_data[sizing][f'pixel_{target_pixel_1}'].append(trace_data[f'pixel_{target_pixel_1}'][i])
        grouped_data[sizing][f'pixel_{target_pixel_2}'].append(trace_data[f'pixel_{target_pixel_2}'][i])

    # ---------- Plot for pixel 1 ----------
    fig1, ax1 = plt.subplots(figsize=(10, 8))
